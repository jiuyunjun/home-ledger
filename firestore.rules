rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own user record.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // All other collections: only members of the same household.
    // The server-side Go API uses the Admin SDK (bypasses these rules).
    // These rules protect direct client access if ever enabled.
    match /households/{householdId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId == householdId;
      allow write: if false; // server-only
    }

    match /{collection}/{docId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId == resource.data.householdId;
      allow write: if false; // server-only
    }
  }
}
